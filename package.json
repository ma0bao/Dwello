{
  "name": "dwello",
  "version": "1.0.0",
  "type": "module",
  "description": "Dwello property management prototype with static app and email API",
  "main": "server/app.mjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:css && node scripts/build-public.mjs",
    "prestart": "npm run build:css",
    "start": "node server/app.mjs",
    "dev": "nodemon server/app.mjs",
    "build:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c tailwind.config.cjs -i ./src/styles.css -o ./dist/styles.css --minify",
    "watch:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c tailwind.config.cjs -i ./src/styles.css -o ./dist/styles.css --watch",
    "check": "npm run build:css && node --check server/app.mjs && node --check server/db/database.mjs && node --check server/db/seed.mjs && node --check server/routes/properties.mjs && node --check src/bootstrap.js && node --check src/app.js && node --check tests/api.test.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "property-management",
    "email",
    "nodemailer",
    "express",
    "dwello"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^9.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17"
  }
}
