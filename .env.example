# Dwello runtime configuration
# Copy this file to .env for local development.

# Express server port. Defaults to 3000 when unset.
PORT=3000

# SQLite database file. Defaults to ./data/dwello.sqlite when unset.
DB_PATH=./data/dwello.sqlite

# Optional Gmail SMTP credentials used by /api/send-email.
# Create an app password in your Google account; do not use your account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
