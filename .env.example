# Dwello runtime configuration
# Copy this file to .env for local development.

# Express server port. Defaults to 3000 when unset.
PORT=3000

# Supabase credentials — get these from your Supabase project dashboard:
# Settings > API > Project URL / API Keys
SUPABASE_URL=
# Supabase public anon key — safe to expose to browsers (RLS enforces access control)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend API credentials used by /api/send-email.
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
# Optional: Custom "from" email (must be verified in Resend)
# Defaults to 'Dwello <onboarding@resend.dev>' if not set
RESEND_FROM_EMAIL=
